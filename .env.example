# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Database (SQLite by default, or PostgreSQL connection string)
# DATABASE_URL=sqlite:///./sentinel.db
# DATABASE_URL=postgresql://user:password@localhost:5432/sentinel

# Agent behavior
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30

# n8n credentials (optional, for integration workflows)
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password
POSTGRES_DB=n8n

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
